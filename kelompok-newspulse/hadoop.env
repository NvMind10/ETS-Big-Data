CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root
CORE_CONF_hadoop_proxyuser_hive_hosts=*
CORE_CONF_hadoop_proxyuser_hive_groups=*

HDFS_CONF_dfs_namenode_secondary_http_address=0.0.0.0:9868
HDFS_CONF_dfs_namenode_statechange_detailed_count=true
HDFS_CONF_dfs_namenode_delegation_token_max_lifetime=604800000
HDFS_CONF_dfs_datanode_data_dir_perm=700
HDFS_CONF_dfs_namenode_name_dir=/hadoop/dfs/name
HDFS_CONF_dfs_datanode_data_dir=/hadoop/dfs/data

LOG4J_FORMAT_MSG_NO_LOOKUPS=true
